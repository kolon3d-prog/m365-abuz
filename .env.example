# HTTP bind address (default: 127.0.0.1:4141)
M365_LISTEN=127.0.0.1:4141

# OAuth/account cache. Keep this file private and mode 0600.
M365_CONFIG=$HOME/.config/m365-native/accounts.json

# Required administrator password for the web console and management APIs.
# Never commit a real value.
M365_ADMIN_PASSWORD=admin123
